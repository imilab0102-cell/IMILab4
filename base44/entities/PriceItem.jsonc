    },
    "category": {
      "type": "string",
      "enum": [
        "\u041c\u0435\u0442\u0430\u043b\u043e\u043a\u0435\u0440\u0430\u043c\u0456\u043a\u0430",
        "\u0411\u0435\u0437\u043c\u0435\u0442\u0430\u043b\u043e\u0432\u0430 \u043a\u0435\u0440\u0430\u043c\u0456\u043a\u0430",
        "\u0417\u043d\u0456\u043c\u043d\u0435 \u043f\u0440\u043e\u0442\u0435\u0437\u0443\u0432\u0430\u043d\u043d\u044f",
