    "material_cost": {
      "type": "number",
      "default": 0,
      "description": "\u0412\u0438\u0442\u0440\u0430\u0442\u0438 \u043c\u0430\u0442\u0435\u0440\u0456\u0430\u043b\u0443 (\u0433\u0440\u043d)"
