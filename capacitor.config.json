# 1. Видаліть неправильний файл
rm capacitor.config.json

# 2. Створіть правильний файл (БЕЗ команди cat)
cat > capacitor.config.json << 'EOF'
{
  "appId": "com.imilab.app",
  "appName": "IMI Lab4",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#ffffff",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    }
  }
}
EOF
